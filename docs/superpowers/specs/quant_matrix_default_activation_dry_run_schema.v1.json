{
  "schema_version": "quant_matrix_default_activation_dry_run_schema_v1",
  "default_activation_dry_run_schema": "quant_matrix_default_activation_dry_run_v1",
  "comparison_schema": "quant_matrix_default_activation_dry_run_comparison_v1",
  "purpose": "Defines the Phase 9 no-RAW default activation dry-run expected-diff gate. The gate reruns manifest-driven QuantMatrixVersion activation in a temporary directory, compares the candidate outputs with the Phase 7 real bundle, and writes only comparison/summary artifacts. It does not activate ProductWriter or write default matrix outputs.",
  "output_files": {
    "summary_json": "quant_matrix_default_activation_dry_run_summary.json",
    "comparison_tsv": "default_activation_dry_run_comparison.tsv"
  },
  "comparison_columns": [
    "schema_version",
    "artifact_label",
    "reference_artifact_path",
    "reference_sha256",
    "dry_run_sha256",
    "sha256_match",
    "meaning"
  ],
  "summary_required_fields": [
    "schema_version",
    "phase",
    "status",
    "default_activation_dry_run_gate_status",
    "source_run_id",
    "downstream_scope",
    "accepted_backfill_count",
    "promotion_packet_readiness_label",
    "dry_run_expected_diff_count",
    "dry_run_written_backfill_count",
    "dry_run_unused_expected_diff_count",
    "dry_run_expected_diff_acceptance_status",
    "comparison_row_count",
    "all_reference_outputs_match",
    "dry_run_only",
    "read_only",
    "write_authority",
    "scorer_ran",
    "raw_or_85raw_ran",
    "product_writer_changed",
    "default_quant_matrix_changed",
    "default_matrix_files_written",
    "workbook_or_gui_changed",
    "selected_peak_area_or_counting_changed",
    "broad_backfill_unparked",
    "may_enter_product_ready_closeout",
    "input_artifacts",
    "artifacts"
  ],
  "binding_rules": {
    "promotion_packet_v2_must_validate": true,
    "real_bundle_must_validate": true,
    "default_check_only_must_match_current_511_source_run": true,
    "default_check_only_must_match_current_511_downstream_scope": true,
    "default_check_only_must_match_511_accepted_backfills": true,
    "dry_run_activation_reruns_in_temp_dir": true,
    "comparison_tsv_must_match_rerun": true,
    "quant_matrix_cell_provenance_row_summary_and_expected_diff_summary_hashes_must_match_phase7_reference": true,
    "source_summary_input_hashes_must_match_phase7_inputs": true
  },
  "authority_rules": {
    "dry_run_only": true,
    "read_only": true,
    "write_authority": false,
    "scorer_ran": false,
    "raw_or_85raw_ran": false,
    "product_writer_changed": false,
    "default_quant_matrix_changed": false,
    "default_matrix_files_written": false,
    "workbook_or_gui_changed": false,
    "selected_peak_area_or_counting_changed": false,
    "broad_backfill_unparked": false
  },
  "promotion_claim": {
    "default_activation_dry_run_gate_status": "pass",
    "may_enter_product_ready_closeout": true,
    "meaning": "This allows Phase 10 Product Ready closeout review to proceed; it does not itself activate ProductWriter or change default outputs."
  }
}
