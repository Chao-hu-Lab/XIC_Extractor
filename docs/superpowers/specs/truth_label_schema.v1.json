{
  "schema_version": "truth_label_schema_v1",
  "purpose": "Independent peak-choice and area truth labels for lockbox cases. These labels are truth-acquisition evidence, not ProductWriter authority.",
  "required_manifest_columns": [
    "schema_version",
    "lockbox_case_id",
    "lockbox_split_id",
    "split_basis",
    "source_stratum",
    "candidate_universe",
    "row_id",
    "family_id",
    "sample_id",
    "analyte",
    "mechanical_decision",
    "evidence_grade",
    "source_write_authority",
    "review_packet_id",
    "candidate_value_if_any",
    "candidate_area",
    "candidate_height",
    "candidate_apex_rt_min",
    "candidate_start_rt_min",
    "candidate_end_rt_min",
    "trace_data_path",
    "overlay_png_path",
    "known_blockers",
    "risk_tags",
    "label_task",
    "required_reviewer_count",
    "truth_label_status",
    "allowed_truth_labels",
    "peak_choice_label_required",
    "area_label_required",
    "source_artifacts",
    "source_hashes",
    "may_touch_matrix",
    "may_grant_product_authority",
    "notes"
  ],
  "required_label_log_columns": [
    "schema_version",
    "lockbox_case_id",
    "reviewer_id",
    "reviewed_at_utc",
    "peak_choice_label",
    "area_label",
    "area_error_direction",
    "reviewer_confidence",
    "evidence_viewed",
    "round_trip_oracle_used",
    "reviewer_notes",
    "decision_hash"
  ],
  "allowed_peak_choice_labels": [
    "correct_peak",
    "wrong_peak",
    "no_peak",
    "unresolved"
  ],
  "allowed_area_labels": [
    "area_acceptable",
    "area_error",
    "boundary_error",
    "not_assessed",
    "unavailable"
  ],
  "reviewer_contract": {
    "minimum_independent_reviewers_per_case": 2,
    "must_label_peak_choice_separately_from_area": true,
    "must_record_disagreement": true,
    "round_trip_oracle_used_must_be_false": true,
    "free_form_value_entry_allowed": false
  },
  "authority_rules": {
    "may_touch_matrix": false,
    "may_grant_product_authority": false,
    "product_writer_consumption": "forbidden_without_later_authority_manifest_and_expected_diff_goal",
    "truth_labels_do_not_mutate_matrix": true,
    "truth_labels_do_not_silently_switch_selected_peak_or_area": true
  },
  "source_policy": {
    "split_basis": "family_id",
    "round_trip_oracle_is_not_peak_choice_truth": true,
    "istd_is_not_analyte_peak_choice_or_area_truth": true,
    "quality_blockers_are_sampling_context_not_writer_predicates": true
  }
}
