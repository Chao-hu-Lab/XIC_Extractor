{
  "schema_version": "productization_control_plane_schema_v1",
  "purpose": "Machine-checkable current productization lane status. This index summarizes current authority and blockers; it does not replace the control plane narrative.",
  "required_status_index_columns": [
    "schema_version",
    "lane_id",
    "lane_group",
    "readiness_status",
    "owner",
    "current_artifact",
    "artifact_sha256",
    "row_count",
    "write_authority",
    "product_authority_scope",
    "may_touch_matrix",
    "may_change_quant_output",
    "may_change_workbook",
    "may_change_selected_peak",
    "may_change_selected_area",
    "may_change_counted_detection",
    "product_effect",
    "public_surface",
    "control_plane_anchor",
    "handoff_anchor",
    "next_checkpoint",
    "expiration_condition",
    "notes"
  ],
  "allowed_readiness_statuses": [
    "production_ready",
    "production_candidate",
    "parked",
    "blocked",
    "diagnostic_only",
    "frozen",
    "out_of_scope"
  ],
  "authority_rules": {
    "unregistered_scope_policy": "fail_closed",
    "only_allowed_product_writer_scope": "backfill_policy_write_ready_rows",
    "parked_blocked_diagnostic_frozen_out_of_scope_must_not_write": true,
    "quality_explanations_cannot_write": true,
    "review_truth_or_recovery_artifacts_cannot_write": true,
    "handoff_and_control_plane_anchor_required": true
  },
  "required_lane_ids": [
    "backfill_current_write_ready_scope",
    "broad_backfill_autowrite",
    "productization_authority_firewall_v1",
    "mechanical_adjudication_contract_v1",
    "review_packet_workflow_v1",
    "peak_choice_truth_lockbox_v1",
    "missing_overlay_evidence_recovery_v1",
    "quality_explanation_sidecar_v1",
    "targeted_ms1_shape_identity_limited_rescue_v1",
    "targeted_ms1_shape_identity_broader_targets",
    "sample_metadata_order_projection_v1",
    "sample_metadata_role_value_behavior",
    "review_action_candidate_sidecar_v1",
    "review_action_selected_candidate_switch",
    "review_action_manual_boundary_area_writer",
    "calibration_normalization_activation",
    "gui_replay_parity"
  ]
}
