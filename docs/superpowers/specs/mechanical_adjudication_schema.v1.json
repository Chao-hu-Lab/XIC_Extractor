{
  "schema_version": "mechanical_adjudication_schema_v1",
  "status": "active",
  "updated": "2026-06-18",
  "decision_states": [
    "write_ready",
    "review_ready",
    "evidence_required",
    "rejected",
    "parked"
  ],
  "evidence_grades": {
    "A": "registered write authority with expected-diff evidence",
    "C": "candidate has trace-matched evidence but lacks independent peak-choice or area truth",
    "D": "candidate lacks required trace, overlay, or reintegration evidence",
    "P": "lane is parked and cannot grant write authority"
  },
  "required_columns": [
    "schema_version",
    "row_id",
    "family_id",
    "sample_id",
    "analyte",
    "candidate_value_if_any",
    "decision",
    "write_authority",
    "evidence_grade",
    "blockers",
    "next_required_evidence",
    "review_question",
    "source_artifacts",
    "source_hashes",
    "may_touch_matrix",
    "explanation_only",
    "product_authority_scope",
    "product_authority_reason"
  ],
  "authority_rules": {
    "write_authority_true_requires": [
      "decision == write_ready",
      "explanation_only == FALSE",
      "may_touch_matrix == TRUE",
      "product_authority_scope is registered in productization_authority_manifest_v1"
    ],
    "explanation_only_requires_write_authority_false": true,
    "quality_blockers_may_only_explain": true,
    "parked_lanes_may_not_grant_write_authority": true,
    "unregistered_product_authority_scope_policy": "fail_closed"
  }
}
