{
  "schema_version": "review_packet_schema_v1",
  "status": "active",
  "updated": "2026-06-18",
  "purpose": "Structured human approval packets for machine-proposed candidates. Approval records reviewer judgment only; it does not grant ProductWriter authority.",
  "packet_required_columns": [
    "schema_version",
    "review_packet_id",
    "row_id",
    "family_id",
    "sample_id",
    "analyte",
    "packet_status",
    "source_mechanical_decision",
    "source_evidence_grade",
    "candidate_value_if_any",
    "candidate_area",
    "candidate_height",
    "candidate_apex_rt_min",
    "candidate_start_rt_min",
    "candidate_end_rt_min",
    "trace_data_path",
    "overlay_png_path",
    "nearest_competing_peak_context",
    "known_blockers",
    "why_machine_cannot_auto_write",
    "review_question",
    "reviewer_allowed_actions",
    "free_form_value_allowed",
    "approval_grants_product_authority",
    "approval_effect",
    "may_touch_matrix",
    "source_artifacts",
    "source_hashes"
  ],
  "decision_log_required_columns": [
    "schema_version",
    "review_packet_id",
    "row_id",
    "reviewer_decision",
    "reviewer_reason_code",
    "reviewer",
    "reviewed_at",
    "decision_comment",
    "approval_grants_product_authority",
    "may_touch_matrix",
    "source_review_queue_sha256"
  ],
  "packet_statuses": [
    "review_ready",
    "evidence_required",
    "parked"
  ],
  "reviewer_allowed_actions": [
    "approve_candidate",
    "reject_candidate",
    "escalate_unresolved"
  ],
  "authority_rules": {
    "free_form_value_allowed": false,
    "approval_grants_product_authority": false,
    "may_touch_matrix": false,
    "approval_effect": "review_decision_log_only",
    "product_writer_consumption": "forbidden_without_later_authority_manifest_expected_diff_update"
  }
}
