{
  "schema_version": "quant_matrix_default_product_activation_schema_v1",
  "default_product_activation_schema": "quant_matrix_default_product_activation_v1",
  "output_comparison_schema": "quant_matrix_default_product_activation_check_v1",
  "purpose": "Defines the explicit ProductWriter/default output activation gate for the default QuantMatrix. The gate writes default numeric quant matrix outputs from the validated ProductionAcceptanceManifest and expected-diff contract, so the default matrix contains detected values plus the current accepted Backfill values.",
  "output_files": {
    "summary_json": "quant_matrix_default_product_activation_summary.json",
    "check_tsv": "default_product_activation_checks.tsv",
    "quant_matrix": "default_output/quant_matrix.tsv",
    "cell_provenance": "default_output/cell_provenance.tsv",
    "row_summary": "default_output/row_summary.tsv",
    "expected_diff_summary": "default_output/expected_diff_summary.tsv",
    "source_summary": "default_output/source_summary.tsv"
  },
  "check_columns": [
    "schema_version",
    "check_id",
    "status",
    "source",
    "meaning"
  ],
  "summary_required_fields": [
    "schema_version",
    "phase",
    "status",
    "activation_label",
    "source_run_id",
    "downstream_scope",
    "accepted_backfill_count",
    "expected_diff_count",
    "written_backfill_count",
    "unused_expected_diff_count",
    "detected_cell_count",
    "accepted_backfill_cell_count",
    "quant_available_cell_count",
    "all_reference_outputs_match",
    "check_count",
    "read_only",
    "write_authority",
    "product_authority_scope",
    "scorer_ran",
    "raw_or_85raw_ran",
    "product_writer_changed",
    "default_quant_matrix_changed",
    "default_matrix_files_written",
    "workbook_or_gui_changed",
    "selected_peak_area_or_counting_changed",
    "broad_backfill_unparked",
    "accepted_backfill_values_are_detection",
    "input_artifacts",
    "artifacts",
    "authority_statement"
  ],
  "binding_rules": {
    "product_ready_closeout_must_validate": true,
    "real_bundle_must_validate": true,
    "default_check_only_must_match_current_511_source_run": true,
    "default_check_only_must_match_current_511_downstream_scope": true,
    "default_check_only_must_match_511_accepted_backfills": true,
    "input_artifact_hashes_must_match": true,
    "expected_diff_summary_must_pass": true,
    "default_outputs_must_match_expected_diff_bound_quant_matrix_version": true,
    "detected_only_claims_must_remain_reconstructable_from_cell_provenance": true,
    "checks_tsv_must_match_outputs": true
  },
  "authority_rules": {
    "read_only": false,
    "write_authority": true,
    "product_authority_scope": "backfill_policy_write_ready_rows",
    "scorer_ran": false,
    "raw_or_85raw_ran": false,
    "product_writer_changed": true,
    "default_quant_matrix_changed": true,
    "default_matrix_files_written": true,
    "workbook_or_gui_changed": false,
    "selected_peak_area_or_counting_changed": false,
    "broad_backfill_unparked": false,
    "accepted_backfill_values_are_detection": false
  },
  "activation_claim": {
    "activation_label": "product_ready_default_matrix_activated",
    "meaning": "Default quant matrix files are now explicitly written from the expected-diff-bound QuantMatrixVersion contract. Accepted Backfill values enter the default numeric matrix as quantification values, not as detections or truth claims."
  }
}
