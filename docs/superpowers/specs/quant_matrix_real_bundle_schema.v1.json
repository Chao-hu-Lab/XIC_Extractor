{
  "schema_version": "quant_matrix_real_bundle_schema_v1",
  "real_bundle_schema": "quant_matrix_real_bundle_v1",
  "purpose": "Defines the Phase 7 no-RAW real QuantMatrixVersion bundle assembled from the current standard-peak Backfill authority replay. The bundle is a contract/readiness artifact only: it does not change ProductWriter defaults, workbook/GUI behavior, selected peak/area, counted detections, broad Backfill authority, or default extraction.",
  "output_files": {
    "summary_json": "quant_matrix_real_bundle_summary.json",
    "baseline_quant_matrix": "inputs/baseline_quant_matrix.tsv",
    "input_matrix_identity": "inputs/alignment_matrix_identity.tsv",
    "production_acceptance_manifest": "inputs/production_acceptance_manifest.tsv",
    "expected_diff": "inputs/expected_diff.tsv",
    "source_artifacts": "source_artifacts/",
    "quant_matrix_version": "quant_matrix_version/",
    "review": "review/",
    "downstream_impact": "downstream_impact/",
    "readiness": "readiness/"
  },
  "summary_required_fields": [
    "schema_version",
    "phase",
    "status",
    "bundle_kind",
    "validation_status",
    "source_run_id",
    "accepted_backfill_count",
    "downstream_scope",
    "read_only",
    "scorer_ran",
    "raw_or_85raw_ran",
    "product_writer_changed",
    "default_quant_matrix_changed",
    "broad_backfill_unparked",
    "may_promote_default_quant_matrix",
    "source_artifacts",
    "original_source_artifacts",
    "artifacts"
  ],
  "binding_rules": {
    "bundle_kind_must_be_real_quant_matrix_version": true,
    "default_check_only_must_match_current_511_source_run": true,
    "default_check_only_must_match_current_511_downstream_scope": true,
    "default_check_only_must_match_511_accepted_backfills": true,
    "source_artifact_copies_have_hashes": true,
    "original_source_artifacts_have_hashes": true,
    "production_acceptance_manifest_must_validate": true,
    "expected_diff_summary_must_pass": true,
    "cell_provenance_accepted_count_must_match_summary": true,
    "downstream_impact_smoke_must_validate": true,
    "readiness_must_remain_contract_ready_science_inconclusive": true
  },
  "authority_rules": {
    "read_only": true,
    "scorer_ran": false,
    "raw_or_85raw_ran": false,
    "product_writer_changed": false,
    "default_quant_matrix_changed": false,
    "broad_backfill_unparked": false,
    "may_promote_default_quant_matrix": false,
    "does_not_change_selected_peak_area_or_counting": true,
    "does_not_change_workbook_or_gui": true
  }
}
