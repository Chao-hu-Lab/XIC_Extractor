{
  "schema_version": "quant_matrix_product_ready_closeout_schema_v1",
  "product_ready_closeout_schema": "quant_matrix_product_ready_closeout_v1",
  "check_schema": "quant_matrix_product_ready_closeout_check_v1",
  "purpose": "Defines the Phase 10 no-RAW Product Ready closeout packet for the default QuantMatrix candidate. The packet collects Phase 8 promotion packet v2 and Phase 9 default activation dry-run evidence into one activation-ready candidate statement without changing ProductWriter defaults or matrix authority.",
  "output_files": {
    "summary_json": "quant_matrix_product_ready_closeout_summary.json",
    "checks_tsv": "quant_matrix_product_ready_closeout_checks.tsv"
  },
  "check_columns": [
    "schema_version",
    "check_id",
    "status",
    "source",
    "meaning"
  ],
  "summary_required_fields": [
    "schema_version",
    "phase",
    "status",
    "closeout_label",
    "source_run_id",
    "downstream_scope",
    "accepted_backfill_count",
    "promotion_packet_readiness_label",
    "promotion_packet_production_ready",
    "promotion_packet_may_promote_default_quant_matrix",
    "dry_run_gate_status",
    "dry_run_expected_diff_count",
    "dry_run_written_backfill_count",
    "dry_run_unused_expected_diff_count",
    "all_reference_outputs_match",
    "check_count",
    "product_ready_candidate",
    "default_quant_matrix_product_ready_candidate",
    "may_activate_default_quant_matrix_with_explicit_contract",
    "requires_product_writer_activation_commit",
    "explicit_activation_not_in_this_commit",
    "read_only",
    "write_authority",
    "scorer_ran",
    "raw_or_85raw_ran",
    "product_writer_changed",
    "default_quant_matrix_changed",
    "default_matrix_files_written",
    "workbook_or_gui_changed",
    "selected_peak_area_or_counting_changed",
    "broad_backfill_unparked",
    "input_artifacts",
    "artifacts",
    "activation_contract",
    "authority_statement",
    "residual_risks"
  ],
  "binding_rules": {
    "default_check_only_must_match_current_511_source_run": true,
    "default_check_only_must_match_current_511_downstream_scope": true,
    "default_check_only_must_match_511_accepted_backfills": true,
    "promotion_packet_v2_must_validate": true,
    "default_activation_dry_run_must_validate": true,
    "input_artifact_hashes_must_match": true,
    "checks_tsv_must_match_inputs": true,
    "phase8_and_phase9_source_identity_must_match": true,
    "expected_diff_must_close_with_zero_unused_rows": true
  },
  "authority_rules": {
    "read_only": true,
    "write_authority": false,
    "scorer_ran": false,
    "raw_or_85raw_ran": false,
    "product_writer_changed": false,
    "default_quant_matrix_changed": false,
    "default_matrix_files_written": false,
    "workbook_or_gui_changed": false,
    "selected_peak_area_or_counting_changed": false,
    "broad_backfill_unparked": false,
    "requires_explicit_activation_commit": true
  },
  "closeout_claim": {
    "closeout_label": "product_ready_default_matrix_candidate",
    "product_ready_candidate": true,
    "default_quant_matrix_product_ready_candidate": true,
    "may_activate_default_quant_matrix_with_explicit_contract": true,
    "meaning": "The default QuantMatrix candidate is ready for an explicit activation commit that wires ProductWriter/default outputs to the expected-diff-bound contract. This closeout does not itself activate ProductWriter or write default matrix outputs."
  }
}
