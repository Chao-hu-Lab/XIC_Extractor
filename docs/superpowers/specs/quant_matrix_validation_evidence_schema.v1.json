{
  "schema_version": "quant_matrix_validation_evidence_schema_v1",
  "validation_evidence_schema": "quant_matrix_validation_evidence_v1",
  "packet_summary_schema": "quant_matrix_validation_evidence_packet_summary_v1",
  "purpose": "Defines the no-RAW artifact-bound validation evidence packet consumed by QuantMatrix Promotion Readiness v1. It records source artifacts, copied packet artifacts, hashes, tier provenance, and missing science evidence without granting matrix authority.",
  "validation_evidence_json": "quant_matrix_validation_evidence_v1.json",
  "validation_evidence_rows_tsv": "quant_matrix_validation_evidence_rows.tsv",
  "summary_json": "quant_matrix_validation_evidence_summary.json",
  "downstream_impact_artifact_schema": "quant_matrix_downstream_impact_smoke_v1",
  "evidence_row_columns": [
    "schema_version",
    "tier",
    "status",
    "artifact_path",
    "artifact_sha256",
    "source_artifact_path",
    "source_artifact_sha256",
    "cohort_id",
    "raw_run_count",
    "oracle_packet_id",
    "review_packet_id",
    "downstream_scope",
    "evidence_note"
  ],
  "allowed_tiers": [
    "85raw_large_cohort",
    "large_cohort_validation",
    "heldout_oracle",
    "manual_review_oracle",
    "downstream_impact_smoke",
    "focused_tests",
    "8raw_smoke"
  ],
  "allowed_status": [
    "pass",
    "fail"
  ],
  "required_science_evidence": {
    "large_cohort_validation": [
      "85raw_large_cohort",
      "large_cohort_validation"
    ],
    "heldout_oracle_or_manual_review": [
      "heldout_oracle",
      "manual_review_oracle"
    ],
    "downstream_impact_smoke": [
      "downstream_impact_smoke"
    ]
  },
  "required_tier_metadata": {
    "85raw_large_cohort": [
      "cohort_id",
      "raw_run_count"
    ],
    "large_cohort_validation": [
      "cohort_id"
    ],
    "heldout_oracle": [
      "oracle_packet_id"
    ],
    "manual_review_oracle": [
      "review_packet_id"
    ],
    "downstream_impact_smoke": [
      "downstream_scope"
    ]
  },
  "binding_rules": {
    "artifact_path_is_packet_relative_child": true,
    "artifact_sha256_must_match_copied_artifact": true,
    "source_artifact_path_and_sha256_are_required": true,
    "duplicate_tiers_fail_closed": true,
    "missing_required_science_evidence_stays_inconclusive": true,
    "downstream_impact_smoke_must_validate_artifact_content": true,
    "downstream_impact_contract_fixture_cannot_satisfy_promotion": true
  },
  "authority_rules": {
    "read_only": true,
    "write_authority": false,
    "does_not_run_scorer": true,
    "does_not_read_raw_or_85raw": true,
    "does_not_change_product_writer": true,
    "does_not_change_default_quant_matrix": true,
    "does_not_change_workbook_or_gui": true,
    "does_not_change_selected_peak_area_or_counting": true
  }
}
