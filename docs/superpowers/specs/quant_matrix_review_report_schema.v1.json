{
  "schema_version": "quant_matrix_review_report_schema_v1",
  "review_schema_version": "quant_matrix_review_report_v1",
  "purpose": "Defines the Phase 4 review-only report outputs rendered from QuantMatrixVersion v1 sidecars and the validated ProductionAcceptanceManifest. This schema does not change ProductWriter default extraction, workbooks, GUI behavior, selected peaks, selected areas, counted detections, or matrix authority.",
  "outputs": {
    "review_rows": "quant_matrix_review_rows.tsv",
    "summary_json": "quant_matrix_review_summary.json",
    "html": "quant_matrix_review_report.html"
  },
  "review_row_columns": [
    "schema_version",
    "peak_hypothesis_id",
    "source_feature_family_ids",
    "sample_stem",
    "cell_status",
    "matrix_value",
    "report_authority",
    "write_authority",
    "acceptance_decision",
    "acceptance_basis",
    "truth_status",
    "prevalence_review_state",
    "prevalence_flags",
    "triggered_risk_rule_ids",
    "closure_rule_ids",
    "trace_basis",
    "boundary_status",
    "manual_negative_closure",
    "doublet_closure",
    "doublet_status",
    "reference_side",
    "doublet_allowed",
    "quant_value_source",
    "matrix_area_source",
    "decision_reason",
    "next_evidence_needed",
    "source_artifact_relpath",
    "source_artifact_sha256",
    "source_row_sha256",
    "doublet_source_relpath",
    "doublet_source_sha256",
    "manifest_sha256"
  ],
  "authority_rules": {
    "report_only": true,
    "does_not_mutate_quant_matrix": true,
    "does_not_change_product_writer": true,
    "does_not_change_workbook_gui_selected_peak_area_or_counting": true,
    "accepted_backfill_rows_must_join_back_to_manifest": true,
    "source_summary_manifest_file_sha256_must_match_current_manifest_file": true,
    "accepted_backfill_manifest_join_must_match_manifest_sha256": true,
    "accepted_backfill_manifest_join_must_match_source_row_sha256": true,
    "accepted_backfill_manifest_join_must_preserve_authority_flags": true,
    "manual_negative_and_blocked_doublet_closure_are_displayed_not_overridden": true,
    "report_only_prevalence_risks_remain_non_authority": true,
    "gaussian_smoothed_trace_is_primary_raw_trace_is_auxiliary": true
  },
  "next_phase": "validation_promotion_readiness"
}
