{
  "schema_version": "quant_matrix_promotion_readiness_schema_v1",
  "readiness_schema_version": "quant_matrix_promotion_readiness_v1",
  "summary_json": "quant_matrix_promotion_readiness_summary.json",
  "checks_tsv": "quant_matrix_promotion_readiness_checks.tsv",
  "promotion_check_columns": [
    "schema_version",
    "check_id",
    "category",
    "status",
    "severity",
    "evidence",
    "next_action"
  ],
  "summary_fields": [
    "schema_version",
    "contract_correctness_status",
    "scientific_confidence_status",
    "readiness_label",
    "production_ready",
    "may_promote_default_quant_matrix",
    "missing_science_evidence",
    "blockers",
    "validation_tiers",
    "input_artifacts",
    "authority_statement"
  ],
  "readiness_labels": [
    "contract_failed",
    "contract_ready_science_failed",
    "contract_ready_science_inconclusive",
    "production_ready_candidate_packet"
  ],
  "required_science_evidence": {
    "large_cohort_validation": [
      "85raw_large_cohort",
      "large_cohort_validation"
    ],
    "heldout_oracle_or_manual_review": [
      "heldout_oracle",
      "manual_review_oracle"
    ],
    "downstream_impact_smoke": [
      "downstream_impact_smoke"
    ]
  },
  "required_science_tier_provenance": {
    "85raw_large_cohort": [
      "artifact_path",
      "artifact_sha256",
      "cohort_id",
      "raw_run_count"
    ],
    "large_cohort_validation": [
      "artifact_path",
      "artifact_sha256",
      "cohort_id"
    ],
    "heldout_oracle": [
      "artifact_path",
      "artifact_sha256",
      "oracle_packet_id"
    ],
    "manual_review_oracle": [
      "artifact_path",
      "artifact_sha256",
      "review_packet_id"
    ],
    "downstream_impact_smoke": [
      "artifact_path",
      "artifact_sha256",
      "downstream_scope"
    ]
  },
  "authority_rules": {
    "contract_correctness_is_not_science": true,
    "focused_tests_cannot_claim_production_ready": true,
    "eight_raw_smoke_cannot_claim_production_ready": true,
    "required_science_pass_rows_must_be_artifact_bound": true,
    "duplicate_validation_tiers_fail_closed": true,
    "production_ready_requires_contract_and_science_pass": true,
    "checker_is_read_only": true
