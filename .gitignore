# Python
.venv/
.uv-cache/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Test / lint caches
.coverage
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tmp/
tmp_runtime/

# Local secrets / machine-specific overrides
.env
.env.*

# Output (generated files)
output/
!xic_extractor/output/
!xic_extractor/output/*.py
local_raw_samples/
local_validation_raw/
local_validation_artifacts/

# Superpowers / Claude dev artefacts
.agents/
.superpowers/
.remember/
.codegraph/
graphify-out/
.worktrees/
.codex/config.toml
.codex/execpolicy/
progress-report.html
progress-report.notes.json
progress-report.snapshot.json
progress-report.server-info.json

# Local/private handoff workspace.
# Transient branch handoffs and completed phase diaries should stay local or move
# to Obsidian by default. Force-add only compact public summaries that are meant
# to remain in repo history.
docs/superpowers/handoffs/current/*
docs/superpowers/handoffs/archive/*

# Private user config/profiles (only examples are versioned)
config/*
!config/env.example
!config/settings.example.csv
!config/targets.example.csv
!config/MixSTDs.csv
